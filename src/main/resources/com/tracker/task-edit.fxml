<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" prefHeight="500.0" prefWidth="460.0" spacing="25.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.EditTaskController">
   <children>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label alignment="TOP_CENTER" contentDisplay="CENTER" prefHeight="50.0" prefWidth="155.0" style="-fx-font-size: 30px; -fx-font-weight: Bold; -fx-label-padding: 6 14;" text="Edit Task" textAlignment="CENTER" />
         </children>
      </HBox>
      <TextField fx:id="taskTitle" promptText="Enter Title" />
      <HBox prefHeight="24.0" prefWidth="410.0" spacing="30.0">
         <children>
            <VBox prefHeight="200.0" prefWidth="120.0">
               <children>
                  <DatePicker fx:id="dueDate" prefHeight="25.0" prefWidth="125.0" promptText="Due Date" />
               </children>
            </VBox>
            <VBox prefHeight="200.0" prefWidth="130.0">
               <children>
                  <ChoiceBox fx:id="taskTypeDropDown" prefHeight="25.0" prefWidth="129.0" />
               </children>
            </VBox>
            <VBox prefHeight="200.0" prefWidth="100.0">
               <children>
                  <ChoiceBox fx:id="priorityDropDown" prefHeight="25.0" prefWidth="108.0" />
               </children>
            </VBox>
         </children>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </HBox>
      <HBox alignment="CENTER" prefHeight="37.0" prefWidth="410.0" spacing="10.0">
         <children>
            <VBox alignment="CENTER_LEFT" prefHeight="37.0" prefWidth="145.0">
               <HBox.margin>
                  <Insets />
               </HBox.margin>
               <children>
                  <Button fx:id="handleDeleteButton" mnemonicParsing="false" text="Delete" textFill="RED" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="16.0" prefWidth="83.0" />
            <VBox alignment="CENTER_RIGHT" prefHeight="25.0" prefWidth="59.0" />
            <VBox alignment="CENTER" prefHeight="200.0" prefWidth="100.0">
               <children>
                  <CheckBox fx:id="markComplete" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="35.0" prefWidth="93.0" style="-fx-font-weight: bold;" text="Completed" textAlignment="CENTER" textFill="#0dbf1f" wrapText="true">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </CheckBox>
               </children>
            </VBox>
         </children>
         <rotationAxis>
            <Point3D x="1.0" z="1.0" />
         </rotationAxis>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </HBox>
      <VBox prefHeight="200.0" prefWidth="100.0">
         <children>
            <TextArea fx:id="taskDetails" prefHeight="200.0" prefWidth="200.0" />
         </children>
      </VBox>
      <HBox alignment="CENTER" prefHeight="18.0" prefWidth="410.0">
         <children>
            <VBox alignment="CENTER_LEFT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Button fx:id="handleCancelButton" alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" prefHeight="25.0" prefWidth="100.0" text="Cancel" textAlignment="CENTER">
                     <opaqueInsets>
                        <Insets />
                     </opaqueInsets>
                  </Button>
               </children>
            </VBox>
            <VBox alignment="CENTER_RIGHT" prefHeight="25.0" prefWidth="200.0">
               <children>
                  <Button fx:id="handleSaveButton" mnemonicParsing="false" prefHeight="25.0" prefWidth="100.0" text="Save Task" />
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="30.0" />
   </padding>
</VBox>
