<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" spacing="12.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.tracker.TaskAddController">
   <children>
      <Label text="Add new task" textAlignment="CENTER">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
            <TextField fx:id="txtField_taskTitle" prefHeight="26.0" prefWidth="507.0" promptText="Enter new title" />
      <HBox>
         <children>
                  <DatePicker fx:id="datePicker_dueDate" minWidth="90.0" prefWidth="100.0" />
            <Region HBox.hgrow="ALWAYS" />
            <ChoiceBox fx:id="choiceBox_priority" prefWidth="150.0" />
            <Region HBox.hgrow="ALWAYS" />
            <ChoiceBox fx:id="choiceBox_taskType" prefWidth="150.0" />
         </children>
      </HBox>
            <TextArea fx:id="textArea_description" prefHeight="200.0" prefWidth="507.0" VBox.vgrow="ALWAYS" />
      <HBox alignment="CENTER" spacing="36.0">
         <children>
                  <Button fx:id="btn_cancel" mnemonicParsing="false" onAction="#cancelAction" prefHeight="26.0" prefWidth="122.0" text="Cancel" />
                  <Button fx:id="btn_addTask" defaultButton="true" mnemonicParsing="false" onAction="#handleAddTask" prefHeight="26.0" prefWidth="122.0" text="Add Task" />
         </children>
      </HBox>
         </children>
         <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0" />
         </padding>
      </VBox>
