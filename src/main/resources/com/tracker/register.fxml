<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.tracker.RegisterController"
      alignment="CENTER" spacing="12"
      style="-fx-background-color: white;">
    <padding><Insets top="50" right="60" bottom="50" left="60"/></padding>

    <Label text="Register a new user"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="6" maxWidth="280">
        <Label text="Username"/>
        <TextField fx:id="usernameField" promptText="enter username here" maxWidth="Infinity"/>

        <Label text="Password"/>
        <PasswordField fx:id="passwordField" promptText="enter password" maxWidth="Infinity"/>

        <Label text="Confirm Password"/>
        <PasswordField fx:id="confirmField" promptText="confirm password" maxWidth="Infinity"/>

        <Label fx:id="messageLabel" text=""
               style="-fx-font-size: 11px;" wrapText="true"/>

        <Button text="Register New User" onAction="#handleRegister"
                maxWidth="Infinity"
                style="-fx-background-color: #aac4e0; -fx-font-size: 13px; -fx-padding: 8;"/>

        <Button text="Return to Start" onAction="#handleReturnToStart"
                maxWidth="Infinity"
                style="-fx-background-color: #f0f0f0; -fx-font-size: 12px; -fx-padding: 7;"/>
    </VBox>
</VBox>