<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.tracker.AdminSettingsController"
            prefWidth="700.0"
            prefHeight="520.0"
            style="-fx-background-color: white;">

    <children>
        <VBox spacing="22.0"
              alignment="TOP_CENTER"
              AnchorPane.topAnchor="30.0"
              AnchorPane.leftAnchor="50.0"
              AnchorPane.rightAnchor="50.0"
              AnchorPane.bottomAnchor="25.0">

            <children>

                <Label text="Admin Settings"
                       style="-fx-font-size: 28px; -fx-font-weight: bold;" />

                <HBox spacing="12.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Default Priority"
                               minWidth="100.0" />
                        <ComboBox fx:id="priorityComboBox"
                                  prefWidth="140.0"
                                  promptText="Priority" />
                    </children>
                </HBox>

                <VBox spacing="10.0" prefWidth="520.0" maxWidth="520.0">
                    <children>

                        <HBox spacing="12.0" alignment="CENTER_LEFT">
                            <children>
                                <Label text="Task types" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="addTaskTypeButton"
                                        text="Add New Task Type"
                                        onAction="#handleAddTaskType" />
                            </children>
                        </HBox>

                        <TableView fx:id="taskTypeTable"
                                   prefHeight="260.0"
                                   columnResizePolicy="CONSTRAINED_RESIZE_POLICY"
                                   style="-fx-border-color: #d9d9d9; -fx-border-width: 1;">
                            <columns>
                                <TableColumn fx:id="taskTypeNameColumn"
                                             text="Task Type"
                                             prefWidth="260.0" />
                                <TableColumn fx:id="editColumn"
                                             text="Edit"
                                             prefWidth="100.0"
                                             sortable="false" />
                                <TableColumn fx:id="deleteColumn"
                                             text="Delete"
                                             prefWidth="120.0"
                                             sortable="false" />
                            </columns>
                        </TableView>

                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Button fx:id="backButton"
                                text="Back to Dashboard"
                                onAction="#handleBackToDashboard" />
                    </children>
                </HBox>

            </children>

            <padding>
                <Insets top="0.0" right="0.0" bottom="0.0" left="0.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>