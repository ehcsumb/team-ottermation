<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox alignment="TOP_CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
  minWidth="-Infinity" prefHeight="500.0" prefWidth="600.0" spacing="12.0"
  xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
  fx:controller="com.tracker.TaskListController">
  <children>
    <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Task list" textAlignment="CENTER"
      wrappingWidth="311.21630859375">
      <font>
        <Font size="27.0"/>
      </font>
    </Text>
    <Button fx:id="btn_addTask" defaultButton="true" mnemonicParsing="false"
      onAction="#handleAddTask" text="Add New Task">
      <VBox.margin>
        <Insets/>
      </VBox.margin>
    </Button>
    <ScrollPane fitToWidth="true">
      <content>
        <VBox fx:id="taskList_vbox" prefHeight="200.0" prefWidth="100.0"/>
      </content>
    </ScrollPane>
    <Button fx:id="btn_backToDashboard" minHeight="20.0" mnemonicParsing="false"
      onAction="#handleBackToDashboard" text="Back to Dashboard"/>
  </children>
  <padding>
    <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
  </padding>
</VBox>
